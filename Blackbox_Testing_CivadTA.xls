  <Version>16.00</Version>
 </DocumentProperties>
 <OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office">
  <AllowPNG/>
 </OfficeDocumentSettings>
 <ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel">
  <WindowHeight>12435</WindowHeight>
  <WindowWidth>28800</WindowWidth>
  <WindowTopX>0</WindowTopX>
  <WindowTopY>0</WindowTopY>
  <ProtectStructure>False</ProtectStructure>
  <ProtectWindows>False</ProtectWindows>
 </ExcelWorkbook>
 <Styles>
  <Style ss:ID="Default" ss:Name="Normal">
   <Alignment ss:Vertical="Center"/>
   <Borders/>
   <Font ss:FontName="Calibri" x:CharSet="1" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/>
   <Interior/>
   <NumberFormat/>
   <Protection/>
  </Style>
  <Style ss:ID="Title">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center"/>
   <Font ss:FontName="Calibri" ss:Size="16" ss:Bold="1" ss:Color="#1F4E78"/>
  </Style>
  <Style ss:ID="Header">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center" ss:WrapText="1"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#000000"/>
    <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#000000"/>
    <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#000000"/>
    <Border ss:Position="Top" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#000000"/>
   </Borders>
   <Font ss:FontName="Calibri" ss:Size="11" ss:Color="#FFFFFF" ss:Bold="1"/>
   <Interior ss:Color="#1F4E78" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="Bordered">
   <Alignment ss:Vertical="Center" ss:WrapText="1"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Top" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
   </Borders>
  </Style>
  <Style ss:ID="BorderedCenter">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center" ss:WrapText="1"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Top" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
   </Borders>
  </Style>
  <Style ss:ID="Pass">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center"/>
   <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
    <Border ss:Position="Top" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9D9D9"/>
   </Borders>
   <Font ss:FontName="Calibri" ss:Color="#006100" ss:Bold="1"/>
   <Interior ss:Color="#C6EFCE" ss:Pattern="Solid"/>
  </Style>
 </Styles>
 <Worksheet ss:Name="Blackbox Testing CivadTA">
  <Table ss:ExpandedColumnCount="10" x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="20">
   <Column ss:Width="100"/>
   <Column ss:Width="100"/>
   <Column ss:Width="180"/>
   <Column ss:Width="70"/>
   <Column ss:Width="200"/>
   <Column ss:Width="180"/>
   <Column ss:Width="40"/>
   <Column ss:Width="300"/>
   <Column ss:Width="300"/>
   <Column ss:Width="70"/>
   <Row ss:Height="25">
    <Cell ss:MergeAcross="9" ss:StyleID="Title"><Data ss:Type="String">Tabel Pengujian Black Box - CivadTA (CV Arya Duta Tangerang)</Data></Cell>
   </Row>
   <Row ss:Height="10">
    <!-- Empty row for spacing -->
   </Row>
   <Row ss:Height="25">
    <Cell ss:StyleID="Header"><Data ss:Type="String">Scenario ID</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Case ID</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Test</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Type</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Test Case</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Pre Condition</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Steps</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Short Description</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Expected Result</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Status (Pass/Fail)</Data></Cell>
   </Row>

   <!-- Scenario 1: Registrasi -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="7" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.Reg.001</Data></Cell>
    <Cell ss:MergeDown="7" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.Reg.001</Data></Cell>
    <Cell ss:MergeDown="7" ss:StyleID="Bordered"><Data ss:Type="String">Cek registrasi pelanggan baru dengan data valid</Data></Cell>
    <Cell ss:MergeDown="7" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="7" ss:StyleID="Bordered"><Data ss:Type="String">Pelanggan berhasil mendaftarkan akun baru ke sistem</Data></Cell>
    <Cell ss:MergeDown="7" ss:StyleID="Bordered"><Data ss:Type="String">Pelanggan belum memiliki akun pada sistem</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Buka halaman registrasi /register</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Sistem menampilkan halaman form registrasi pelanggan</Data></Cell>
    <Cell ss:MergeDown="7" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Input nama lengkap &quot;John Doe&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom nama terisi &quot;John Doe&quot;</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Input username unik &quot;johndoe&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom username terisi &quot;johndoe&quot;</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Input email unik &quot;johndoe@example.com&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom email terisi &quot;johndoe@example.com&quot;</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">5</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Input password yang valid &quot;Password123&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom password terisi &quot;Password123&quot; (disamarkan)</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">6</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Input konfirmasi password yang sama &quot;Password123&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom konfirmasi password terisi</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">7</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pilih daerah pengiriman &quot;Tangerang&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom daerah terpilih &quot;Tangerang&quot;</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">8</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Daftar&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Sistem memproses data, mengirim email konfirmasi, dan menampilkan halaman login dengan pesan sukses.</Data></Cell>
   </Row>

   <!-- Scenario 2: Login -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="4" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.Login.001</Data></Cell>
    <Cell ss:MergeDown="4" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.Login.001</Data></Cell>
    <Cell ss:MergeDown="4" ss:StyleID="Bordered"><Data ss:Type="String">Cek validasi login dengan data valid</Data></Cell>
    <Cell ss:MergeDown="4" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="4" ss:StyleID="Bordered"><Data ss:Type="String">Pengguna berhasil login menggunakan kredensial yang valid</Data></Cell>
    <Cell ss:MergeDown="4" ss:StyleID="Bordered"><Data ss:Type="String">Pengguna sudah memiliki akun terdaftar pada sistem</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Buka halaman login /login</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Sistem menampilkan form login</Data></Cell>
    <Cell ss:MergeDown="4" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Input username &quot;johndoe&quot; atau &quot;admin&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom username terisi dengan benar</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Input password &quot;Password123&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom password terisi dengan benar</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pilih role (&quot;Pelanggan&quot; atau &quot;Admin&quot;)</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Role terpilih dengan benar</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">5</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Login&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Sistem memvalidasi kredensial, mencocokkan hash password, dan mengarahkan ke dashboard masing-masing.</Data></Cell>
   </Row>

   <!-- Scenario 3: Melihat data pelanggan -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="1" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.ViewCust.001</Data></Cell>
    <Cell ss:MergeDown="1" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.ViewCust.001</Data></Cell>
    <Cell ss:MergeDown="1" ss:StyleID="Bordered"><Data ss:Type="String">Melihat daftar pelanggan terdaftar</Data></Cell>
    <Cell ss:MergeDown="1" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="1" ss:StyleID="Bordered"><Data ss:Type="String">Admin dapat melihat daftar seluruh pelanggan terdaftar</Data></Cell>
    <Cell ss:MergeDown="1" ss:StyleID="Bordered"><Data ss:Type="String">Admin sudah berhasil masuk (login) ke dashboard admin</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Buka menu &quot;Manajemen User&quot; /admin/manajemen-user</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Halaman Manajemen User terbuka menampilkan sub-tabel Admin dan Pelanggan</Data></Cell>
    <Cell ss:MergeDown="1" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Lihat daftar pelanggan pada tabel</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Daftar seluruh pelanggan (nama, email, daerah, poin, dll.) ditampilkan dengan lengkap.</Data></Cell>
   </Row>

   <!-- Scenario 4: Mengelola buku -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.ManageBook.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.ManageBook.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Mengelola data buku (Tambah Buku)</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Admin berhasil menambahkan data buku baru ke database</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Admin sudah login dan berada di halaman manajemen buku</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Buka halaman &quot;Manajemen Buku&quot; /admin/manajemen-buku</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Halaman manajemen buku termuat dan menampilkan daftar buku saat ini</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Tambah Buku&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Modal form tambah buku baru muncul ke layar</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Isi data judul, penulis, kategori, kelas, harga, stok, gambar, dan deskripsi buku</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Seluruh kolom input terisi dengan data buku baru</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Simpan&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Sistem menyimpan buku baru ke database, memuat ulang tabel buku, dan menampilkan pesan sukses.</Data></Cell>
   </Row>

   <!-- Scenario 5: Mengelola pesanan -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.ManageOrder.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.ManageOrder.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Memperbarui status pesanan pelanggan</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Admin berhasil memperbarui status pesanan menjadi Sedang Dikirim</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Terdapat pesanan masuk dari pelanggan dengan status Pending</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Buka halaman &quot;Manajemen Pesanan&quot; /admin/manajemen-pesanan</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Halaman manajemen pesanan terbuka menampilkan tabel daftar pesanan masuk</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pilih pesanan berstatus Pending dan klik &quot;Update Status&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Form/modal update status pesanan ditampilkan</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pilih status &quot;Sedang Dikirim&quot; dan input tracking link kurir</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Status terpilih dan kolom tracking link terisi link pelacakan</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Perbarui Status&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Sistem mengupdate status pesanan menjadi Sedang Dikirim, menyimpan tracking link, mengirimkan notifikasi ke pelanggan, dan menampilkan pesan sukses.</Data></Cell>
   </Row>

   <!-- Scenario 6: Melakukan verifikasi pengembalian -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.VerifyReturn.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.VerifyReturn.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Verifikasi pengajuan retur (Disetujui)</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Admin menyetujui pengajuan pengembalian buku dari pelanggan</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Pelanggan telah mengajukan retur buku (status pesanan: Pengajuan Pending)</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Buka menu &quot;Manajemen Pengembalian&quot; di dashboard admin</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Halaman manajemen pengembalian terbuka menampilkan tabel pengajuan retur</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik &quot;Detail&quot; pada salah satu pengajuan</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Detail alasan, detail bank refund, dan bukti video terlampir muncul</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pilih opsi verifikasi &quot;Disetujui&quot; dan tulis catatan admin</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Status persetujuan dipilih dan catatan terisi</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Simpan&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Status pengembalian diupdate menjadi Disetujui, status pesanan berubah menjadi Dikembalikan, dan notifikasi terkirim ke pelanggan.</Data></Cell>
   </Row>

   <!-- Scenario 7: Melihat laporan penjualan -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="2" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.SalesReport.001</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.SalesReport.001</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="Bordered"><Data ss:Type="String">Melihat dan mengekspor laporan penjualan</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="Bordered"><Data ss:Type="String">Admin berhasil melihat rekap laporan penjualan dan mengunduh berkas CSV</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="Bordered"><Data ss:Type="String">Admin sudah masuk ke sistem</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Buka menu &quot;Laporan Penjualan&quot; /admin/laporan-penjualan</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Halaman laporan penjualan memuat data transaksi selesai</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pilih filter periode (misal: &quot;Bulan ini&quot;)</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Data penjualan disaring, menghitung total pendapatan, jumlah pesanan, dan jumlah buku secara otomatis</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Export Report&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Sistem memproses file dan otomatis mengunduh berkas laporan berformat CSV ke komputer admin.</Data></Cell>
   </Row>

   <!-- Scenario 8: Melihat katalog buku -->
