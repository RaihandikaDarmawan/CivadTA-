    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Detail rekening terisi lengkap</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">5</Data></Cell>
