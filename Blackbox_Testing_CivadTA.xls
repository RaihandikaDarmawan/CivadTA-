   </Row>

   <!-- Scenario 16: Menambah poin -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.AddPoints.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.AddPoints.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Menambahkan poin loyalty pelanggan secara manual</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Admin berhasil memberikan poin loyalty tambahan ke pelanggan</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Admin berada di halaman manajemen user</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Buka halaman &quot;Manajemen User&quot; /admin/manajemen-user</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Tabel data pelanggan ditampilkan lengkap dengan kolom poin loyalty saat ini</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Update Poin&quot; pada baris pelanggan terkait</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Modal pop-up update poin terbuka</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Masukkan jumlah poin tambahan (misal: 100)</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom input poin terisi dengan angka 100</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">4</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Klik tombol &quot;Simpan&quot;</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Sistem menambahkan 100 poin ke saldo pelanggan di database, mengirim notifikasi, dan tabel memperbarui total poin.</Data></Cell>
   </Row>

   <!-- Scenario 17: Melakukan chat -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.OrderChat.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.OrderChat.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Berkomunikasi via chat pesanan</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Pelanggan dan Admin dapat saling mengirim pesan secara real-time</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Pesanan aktif terdaftar di sistem</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pelanggan klik &quot;Chat dengan Admin&quot; pada detail pesanan</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Halaman chatroom pesanan pelanggan termuat</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Pass"><Data ss:Type="String">Pass</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">2</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pelanggan ketik &quot;Apakah pesanan bisa dikirim sekarang?&quot; lalu klik kirim</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pesan tampil di chatroom pelanggan, tersimpan, dan mengirimkan notifikasi ke admin</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Admin membuka rute chat /admin/chat/{order_id}</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Halaman chatroom admin termuat menampilkan pesan pelanggan</Data></Cell>
   </Row>
