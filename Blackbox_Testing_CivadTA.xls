    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Pesan balasan tampil, tersimpan di database, dan notifikasi terkirim ke pelanggan.</Data></Cell>
   </Row>

   <!-- Scenario 18: Memberi ulasan -->
   <Row ss:Height="22">
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TS.GiveReview.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">TC.GiveReview.001</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Beri Ulasan</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="BorderedCenter"><Data ss:Type="String">Positive</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Pelanggan berhasil mengirimkan ulasan produk buku setelah transaksi selesai</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="Bordered"><Data ss:Type="String">Pesanan pelanggan berstatus Selesai dan belum pernah diulas</Data></Cell>
    <Cell ss:StyleID="BorderedCenter"><Data ss:Type="Number">1</Data></Cell>
