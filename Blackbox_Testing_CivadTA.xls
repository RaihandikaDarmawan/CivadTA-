    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Kolom alasan terisi (min 10 karakter)</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">3</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">Upload file video unboxing (.mp4)</Data></Cell>
    <Cell ss:StyleID="Bordered"><Data ss:Type="String">File video berhasil terupload</Data></Cell>
   </Row>
   <Row ss:Height="22">
    <Cell ss:Index="7" ss:StyleID="BorderedCenter"><Data ss:Type="Number">4</Data></Cell>
